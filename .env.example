# Скопируй в .env и заполни нужные значения.
# Переменные вида DATABASE__URL переопределяют вложенные секции config/default.yaml.
# Разделитель для вложенных ключей: двойное подчёркивание (__).

# Подключение к PostgreSQL
# Используется и приложением (pydantic-settings), и Alembic (migrations/env.py)
# При запуске через docker-compose (docker compose up -d):
DATABASE__URL=postgresql://postgres:postgres@localhost:5432/replyradar

# LLM (LM Studio)
# LLM__BASE_URL=http://localhost:1234/v1
# LLM__MODEL=local-model
# LLM__API_KEY=lm-studio

# Embedding
# EMBEDDING__BASE_URL=http://localhost:1234/v1
# EMBEDDING__MODEL=text-embedding-nomic-embed-text-v1.5
